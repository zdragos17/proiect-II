<Window Height="450" ResizeMode="NoResize" Title="Acțiuni Carte" Width="380" WindowStartupLocation="CenterOwner" x:Class="Proiect.EmployeeBookActionWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F5F7FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Background="#A8192E" Grid.Row="0">
            <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Text="Detalii și Stare Carte" VerticalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25,20,25,10">
                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Text="Titlu:"/>
                <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap" x:Name="TitleTextBlock"/>

                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Text="Autor:"/>
                <TextBlock FontSize="14" Margin="0,0,0,10" TextWrapping="Wrap" x:Name="AuthorTextBlock"/>

                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#6C757D" Text="Status curent:"/>
                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#A8192E" Margin="0,0,0,15" x:Name="StatusTextBlock"/>

                <Separator Background="#DEE2E6" Margin="0,5,0,15"/>

                <TextBlock FontWeight="SemiBold" Foreground="#495057" Margin="0,0,0,5" Text="Nume Student / Deținător:"/>
                <TextBox Height="30" Margin="0,0,0,15" Padding="5" x:Name="StudentNameTextBox"/>

                <TextBlock FontWeight="SemiBold" Foreground="#495057" Margin="0,0,0,5" Text="Tip acțiune:" x:Name="ActionLabel"/>
                <ComboBox Height="30" Margin="0,0,0,15" x:Name="ActionComboBox">
                    <ComboBoxItem Content="Împrumutată" IsSelected="True"/>
                    <ComboBoxItem Content="Rezervată"/>
                </ComboBox>
            </StackPanel>
        </ScrollViewer>

        <Border Background="White" BorderBrush="#DEE2E6" BorderThickness="0,1,0,0" Grid.Row="2">
            <Grid Margin="25,0,25,0">
                <Button Background="#6C757D" Click="CloseButton_Click" Content="Închide" Foreground="White" Height="35" HorizontalAlignment="Left" Width="90">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Background="#A8192E" Click="AssignButton_Click" Content="Atribuie Carte" FontWeight="Bold" Foreground="White" Height="35" HorizontalAlignment="Right" Width="130" x:Name="AssignButton">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Background="#28A745" Click="ReturnButton_Click" Content="Eliberează / Returnează" FontWeight="Bold" Foreground="White" Height="35" HorizontalAlignment="Right" Visibility="Collapsed" Width="160" x:Name="ReturnButton">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
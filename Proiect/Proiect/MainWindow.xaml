<Window x:Class="Proiect.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Biblioteca UTCN"
        Height="760"
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F7FA">
        <Border Background="White"
                Width="470"
                Padding="30"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <StackPanel x:Name="StartPanel">
                        <TextBlock Text="Biblioteca UTCN"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Alege ce vrei să faci"
                                   FontSize="15"
                                   Foreground="#666"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,25"/>

                        <Button Content="Autentificare"
                                Height="40"
                                Margin="0,0,0,10"
                                Click="ShowLoginForm_Click"/>

                        <Button Content="Înregistrare"
                                Height="40"
                                Click="ShowRegisterForm_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="LoginPanel" Visibility="Collapsed">
                        <TextBlock Text="Autentificare"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Rol" Margin="0,0,0,5"/>
                        <ComboBox x:Name="LoginRoleComboBox"
                                  Height="35"
                                  Margin="0,0,0,12"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="student"/>
                            <ComboBoxItem Content="angajat"/>
                        </ComboBox>

                        <TextBlock Text="Username" Margin="0,0,0,5"/>
                        <TextBox x:Name="LoginUsernameTextBox"
                                 Height="35"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Parolă" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="LoginPasswordBox"
                                     Height="35"
                                     Margin="0,0,0,20"/>

                        <Button Content="Intră în cont"
                                Height="40"
                                Click="LoginButton_Click"/>

                        <Button Content="Înapoi"
                                Height="35"
                                Margin="0,10,0,0"
                                Click="BackToStart_Click"/>
                    </StackPanel>

                    <StackPanel x:Name="RegisterPanel" Visibility="Collapsed">
                        <TextBlock Text="Înregistrare"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Rol" Margin="0,0,0,5"/>
                        <ComboBox x:Name="RegisterRoleComboBox"
                                  Height="35"
                                  Margin="0,0,0,10"
                                  SelectedIndex="0"
                                  SelectionChanged="RegisterRoleComboBox_SelectionChanged">
                            <ComboBoxItem Content="student"/>
                            <ComboBoxItem Content="angajat"/>
                        </ComboBox>

                        <TextBlock Text="Nume" Margin="0,0,0,5"/>
                        <TextBox x:Name="LastNameTextBox"
                                 Height="35"
                                 Margin="0,0,0,10"
                                 TextChanged="RegisterNameFields_TextChanged"/>

                        <TextBlock Text="Prenume" Margin="0,0,0,5"/>
                        <TextBox x:Name="FirstNameTextBox"
                                 Height="35"
                                 Margin="0,0,0,10"
                                 TextChanged="RegisterNameFields_TextChanged"/>

                        <TextBlock x:Name="FacultyLabel"
                                   Text="Facultate"
                                   Margin="0,0,0,5"/>

                        <ComboBox x:Name="FacultyComboBox"
                                  Height="35"
                                  Margin="0,0,0,10"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Alege facultatea" IsEnabled="False"/>
                            <ComboBoxItem Content="AC"/>
                            <ComboBoxItem Content="ETTI"/>
                            <ComboBoxItem Content="Construcții"/>
                        </ComboBox>

                        <TextBlock x:Name="MatriculationNumberLabel"
                                   Text="Număr matricol"
                                   Margin="0,0,0,5"/>

                        <TextBox x:Name="MatriculationNumberTextBox"
                                 Height="35"
                                 Margin="0,0,0,10"/>

                        <TextBlock x:Name="EmployeeCodeLabel"
                                   Text="Cod angajat"
                                   Margin="0,0,0,5"
                                   Visibility="Collapsed"/>

                        <PasswordBox x:Name="EmployeeCodePasswordBox"
                                     Height="35"
                                     Margin="0,0,0,10"
                                     Visibility="Collapsed"/>

                        <TextBlock Text="Username generat automat" Margin="0,0,0,5"/>
                        <TextBox x:Name="RegisterUsernameTextBox"
                                 Height="35"
                                 Margin="0,0,0,10"
                                 IsReadOnly="True"
                                 Background="#F1F3F5"
                                 Text="Se va genera automat"/>

                        <TextBlock Text="Parolă" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="RegisterPasswordBox"
                                     Height="35"
                                     Margin="0,0,0,10"/>

                        <TextBlock Text="Confirmă parola" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Height="35"
                                     Margin="0,0,0,20"/>

                        <Button Content="Creează cont"
                                Height="40"
                                Click="RegisterButton_Click"/>

                        <Button Content="Înapoi"
                                Height="35"
                                Margin="0,10,0,0"
                                Click="BackToStart_Click"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
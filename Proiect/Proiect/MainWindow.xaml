<Window x:Class="Proiect.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Biblioteca UTCN"
        Height="760"
        Width="1100"
        WindowState="Maximized"
        MinHeight="720"
        MinWidth="1000"
        SizeToContent="Manual"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid>

        <!-- FUNDAL CU IMAGINE FADĂ -->
        <Grid.Background>
            <ImageBrush ImageSource="/Images/library.png"
                Stretch="UniformToFill"
                Opacity="0.18"/>
        </Grid.Background>

        <!-- OVERLAY DESCHIS PESTE IMAGINE -->
        <Rectangle Fill="#F3E7D7"
           Opacity="0.50"/>

        <!-- DECOR STÂNGA -->
        <Border Width="280"
                HorizontalAlignment="Left"
                Background="#A8192E"
                CornerRadius="0,0,70,0"
                Opacity="0.95"/>

        <StackPanel HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="45,55,0,0">
            <TextBlock Text="UTCN"
                       Foreground="White"
                       FontSize="42"
                       FontWeight="Bold"/>

            <TextBlock Text="Biblioteca"
                       Foreground="White"
                       FontSize="18"
                       Margin="0,5,0,0"/>

            <TextBlock Text="Sistem digital pentru gestionarea&#x0a;cărților și a locurilor de studiu."
                       Foreground="#FDECEF"
                       FontSize="14"
                       Margin="0,35,0,0"
                       LineHeight="22"/>
        </StackPanel>

        <!-- CARD CENTRAL -->
        <Border Background="White"
        Width="650"
        Padding="25"
        CornerRadius="18"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Margin="280,0,0,0"
        BorderBrush="#DEE2E6"
        BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="25"
                                  ShadowDepth="2"
                                  Opacity="0.25"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
              VerticalContentAlignment="Center">
                <StackPanel VerticalAlignment="Center">

                    <!-- PAGINA INITIALA -->
                    <StackPanel x:Name="StartPanel">
                        <TextBlock Text="Biblioteca UTCN"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Alege ce vrei să faci"
                                   FontSize="15"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,30"/>

                        <Button Content="Autentificare"
                                Height="46"
                                FontSize="15"
                                Margin="0,0,0,12"
                                Click="ShowLoginForm_Click"/>

                        <Button Content="Înregistrare"
                                Height="46"
                                FontSize="15"
                                Margin="0,0,0,12"
                                Click="ShowRegisterForm_Click"/>

                        <Button Content="Ieșire aplicație"
                                Height="43"
                                FontSize="14"
                                Click="ExitButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#F8D7DA"/>
                                    <Setter Property="Foreground" Value="#721C24"/>
                                    <Setter Property="BorderBrush" Value="#F5C6CB"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F5C6CB"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#F1B0B7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- AUTENTIFICARE -->
                    <StackPanel x:Name="LoginPanel" Visibility="Collapsed">
                        <TextBlock Text="Autentificare"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,22"/>

                        <TextBlock Text="Rol" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox x:Name="LoginRoleComboBox"
                                  Height="38"
                                  Margin="0,0,0,14"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="student"/>
                            <ComboBoxItem Content="angajat"/>
                        </ComboBox>

                        <TextBlock Text="Username" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="LoginUsernameTextBox"
                                 Height="38"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="Parolă" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <PasswordBox x:Name="LoginPasswordBox"
                                     Height="38"
                                     Margin="0,0,0,22"/>

                        <Button Content="Intră în cont"
                                Height="44"
                                Click="LoginButton_Click"/>

                        <Button Content="Înapoi"
                                Height="38"
                                Margin="0,12,0,0"
                                Click="BackToStart_Click"/>
                    </StackPanel>

                    <!-- INREGISTRARE -->
                    <StackPanel x:Name="RegisterPanel" Visibility="Collapsed">
                        <TextBlock Text="Înregistrare"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,20"/>

                        <TextBlock Text="Rol" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox x:Name="RegisterRoleComboBox"
                                  Height="38"
                                  Margin="0,0,0,12"
                                  SelectedIndex="0"
                                  SelectionChanged="RegisterRoleComboBox_SelectionChanged">
                            <ComboBoxItem Content="student"/>
                            <ComboBoxItem Content="angajat"/>
                        </ComboBox>

                        <TextBlock Text="Nume" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="LastNameTextBox"
                                 Height="38"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Prenume" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="FirstNameTextBox"
                                 Height="38"
                                 Margin="0,0,0,12"/>

                        <TextBlock x:Name="FacultyLabel"
                                   Text="Facultate"
                                   Margin="0,0,0,5"
                                   FontWeight="SemiBold"/>

                        <ComboBox x:Name="FacultyComboBox"
                                  Height="38"
                                  Margin="0,0,0,12"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Alege facultatea" IsEnabled="False"/>
                            <ComboBoxItem Content="AC"/>
                            <ComboBoxItem Content="ETTI"/>
                            <ComboBoxItem Content="Construcții"/>
                        </ComboBox>

                        <TextBlock x:Name="MatriculationNumberLabel"
                                   Text="Număr matricol"
                                   Margin="0,0,0,5"
                                   FontWeight="SemiBold"/>

                        <TextBox x:Name="MatriculationNumberTextBox"
                                 Height="38"
                                 Margin="0,0,0,12"/>

                        <TextBlock x:Name="EmployeeCodeLabel"
                                   Text="Cod angajat"
                                   Margin="0,0,0,5"
                                   FontWeight="SemiBold"
                                   Visibility="Collapsed"/>

                        <PasswordBox x:Name="EmployeeCodePasswordBox"
                                     Height="38"
                                     Margin="0,0,0,12"
                                     Visibility="Collapsed"/>

                        <TextBlock Text="Alege Username"
                                   Margin="0,0,0,5"
                                   FontWeight="SemiBold"/>

                        <TextBox x:Name="RegisterUsernameTextBox"
                                 Height="38"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="Parolă" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <PasswordBox x:Name="RegisterPasswordBox"
                                     Height="38"
                                     Margin="0,0,0,12"/>

                        <TextBlock Text="Confirmă parola" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Height="38"
                                     Margin="0,0,0,22"/>

                        <Button Content="Creează cont"
                                Height="44"
                                Click="RegisterButton_Click"/>

                        <Button Content="Înapoi"
                                Height="38"
                                Margin="0,12,0,0"
                                Click="BackToStart_Click"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
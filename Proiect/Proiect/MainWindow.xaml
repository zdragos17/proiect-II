<Window x:Class="Proiect.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proiect"
        mc:Ignorable="d"
        Title="Biblioteca UTCN"
        Height="500"
        Width="700"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F7FA">
        <Border Background="White"
                Width="350"
                Padding="25"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>
                <TextBlock Text="Biblioteca UTCN"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="Username" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameTextBox"
                         Height="30"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Parolă" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox"
                             Height="30"
                             Margin="0,0,0,15"/>

                <TextBlock Text="Rol (pentru înregistrare)" Margin="0,0,0,5"/>
                <ComboBox x:Name="RoleComboBox"
                          Height="30"
                          Margin="0,0,0,20"
                          SelectedIndex="0">
                    <ComboBoxItem Content="student"/>
                    <ComboBoxItem Content="angajat"/>
                </ComboBox>

                <Button Content="Înregistrare"
                        Height="35"
                        Margin="0,0,0,10"
                        Click="RegisterButton_Click"/>

                <Button Content="Autentificare"
                        Height="35"
                        Click="LoginButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
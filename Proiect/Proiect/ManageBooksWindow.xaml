<Window x:Class="Proiect.ManageBooksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestionare Cărți"
        Height="760"
        Width="1100"
        WindowState="Maximized"
        MinHeight="720"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#A8192E">
            <TextBlock Text="Gestiune Bază de Date Cărți" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="25,15,25,0" Orientation="Horizontal">
            <TextBlock Text="Caută carte" VerticalAlignment="Center" FontSize="14" Margin="0,0,15,0"/>

            <Border Width="350" Height="32" CornerRadius="4" BorderBrush="#B0B8C1" BorderThickness="1" Background="White">
                <TextBox x:Name="SearchTextBox" 
                         Background="Transparent" BorderThickness="0" 
                         VerticalContentAlignment="Center" Padding="8,0" FontSize="14"
                         TextChanged="SearchTextBox_TextChanged"/>
            </Border>
        </StackPanel>

        <DataGrid x:Name="AllBooksDataGrid"
                  Grid.Row="2" Margin="25,15,25,10"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  MouseDoubleClick="AllBooksDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding DisplayId}"/>
                <DataGridTextColumn Header="Titlu" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Autor" Binding="{Binding Author}" Width="*"/>
                <DataGridTextColumn Header="Domeniu" Binding="{Binding Subject}" Width="120"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="25,10,25,20">
            <Button Content="Înapoi" Width="100" HorizontalAlignment="Left" Background="#6C757D" Foreground="White" Click="BackButton_Click"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Editează Cartea" Width="130" Background="#A8192E" Foreground="White" Margin="0,0,15,0" Click="EditBookButton_Click"/>
                <Button Content="Șterge Cartea" Width="130" Background="#DC3545" Foreground="White" Click="DeleteBookButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
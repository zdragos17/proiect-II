<Window x:Class="Proiect.BookDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalii Carte" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        UseLayoutRounding="True" 
        SnapsToDevicePixels="True" 
        TextOptions.TextFormattingMode="Display">

    <Border Background="White" CornerRadius="10" BorderBrush="#DEE2E6" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <Border Background="#A8192E" CornerRadius="9,9,0,0">
                <TextBlock Text="Detalii Carte" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="25,20,25,10">
                <TextBlock Text="Titlu:" FontWeight="SemiBold" Foreground="#6C757D" FontSize="12"/>
                <TextBlock x:Name="TitleTextBlock" TextWrapping="Wrap" FontSize="16" FontWeight="Bold" Foreground="#2D2D2D" Margin="0,0,0,15"/>

                <TextBlock Text="Autor:" FontWeight="SemiBold" Foreground="#6C757D" FontSize="12"/>
                <TextBlock x:Name="AuthorTextBlock" TextWrapping="Wrap" FontSize="14" Foreground="#2D2D2D" Margin="0,0,0,15"/>

                <TextBlock Text="Domeniu:" FontWeight="SemiBold" Foreground="#6C757D" FontSize="12"/>
                <TextBlock x:Name="SubjectTextBlock" TextWrapping="Wrap" FontSize="14" Foreground="#2D2D2D" Margin="0,0,0,15"/>

                <TextBlock Text="Status:" FontWeight="SemiBold" Foreground="#6C757D" FontSize="12"/>
                <TextBlock x:Name="StatusTextBlock" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
            </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#F5F7FA" CornerRadius="0,0,9,9" BorderBrush="#DEE2E6" BorderThickness="0,1,0,0">
                <Button Content="Închide" Width="120" Height="35" Background="#6C757D" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Click="CloseButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
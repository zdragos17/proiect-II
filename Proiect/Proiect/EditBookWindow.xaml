<Window x:Class="Proiect.EditBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editează Detalii Carte" Height="400" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Background="#F5F7FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#A8192E">
            <TextBlock Text="Editare Carte" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="25,20,25,10">
            <TextBlock Text="Titlu carte:" FontWeight="SemiBold" Foreground="#495057" Margin="0,0,0,5"/>
            <TextBox x:Name="TitleTextBox" Height="30" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="Autor:" FontWeight="SemiBold" Foreground="#495057" Margin="0,0,0,5"/>
            <TextBox x:Name="AuthorTextBox" Height="30" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="Domeniu (ex: Literatură):" FontWeight="SemiBold" Foreground="#495057" Margin="0,0,0,5"/>
            <TextBox x:Name="SubjectTextBox" Height="30" Padding="5" Margin="0,0,0,15"/>
        </StackPanel>

        <Border Grid.Row="2" Background="White" BorderBrush="#DEE2E6" BorderThickness="0,1,0,0">
            <Grid Margin="25,0,25,0">
                <Button Content="Anulează" Width="90" Height="35" HorizontalAlignment="Left" Background="#6C757D" Foreground="White" Click="CancelButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Actualizează" Width="100" Height="35" HorizontalAlignment="Right" Background="#A8192E" Foreground="White" FontWeight="Bold" Click="SaveButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
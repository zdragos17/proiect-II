<Window x:Class="Proiect.StudyRoomsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Săli de lectură - Rezervare Loc"
        Height="760"
        Width="1100"
        WindowState="Maximized"
        MinHeight="720"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F5F7FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#C51F35">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="UTCN"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"/>

                    <TextBlock Text="Biblioteca"
                               Foreground="White"
                               FontSize="14"
                               Margin="0,0,0,35"/>

                    <Button Content="📚 Catalog Cărți"
                            Height="45"
                            Margin="0,0,0,15"
                            Background="#A8192E"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Click="BackButton_Click"/>

                    <Button Content="📖 Cărțile Mele"
                            Height="45"
                            Margin="0,0,0,15"
                            Background="#A8192E"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Click="MyBooksButton_Click"/>

                    <Button Content="🏛 Săli de lectură"
                            Height="45"
                            Background="#8F1527"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Content="⎋ Ieșire cont"
                            Height="35"
                            Margin="0,0,0,10"
                            Background="#C51F35"
                            Foreground="White"
                            BorderBrush="White"
                            BorderThickness="1"
                            Click="LogoutButton_Click"/>

                    <Button Content="✕ Închide aplicația"
                            Height="35"
                            Background="#C51F35"
                            Foreground="White"
                            BorderBrush="White"
                            BorderThickness="1"
                            Click="ExitButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Rezervare Loc de Studiu"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#2D2D2D"/>

                <TextBlock Text="Alege un loc disponibil (verde) pentru a-l rezerva."
                           FontSize="14"
                           Foreground="#6C757D"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="8"
                    Padding="25"
                    BorderBrush="#DEE2E6"
                    BorderThickness="1">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="TablesItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="220"
                                        Height="230"
                                        Margin="15"
                                        Padding="15"
                                        CornerRadius="10"
                                        BorderBrush="#DEE2E6"
                                        BorderThickness="1"
                                        Background="#FAFAFA">

                                    <StackPanel>
                                        <TextBlock Text="{Binding TableName}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,15"/>

                                        <ItemsControl ItemsSource="{Binding Seats}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel HorizontalAlignment="Center"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Width="70"
                                                            Height="60"
                                                            Margin="7"
                                                            Content="{Binding SeatNumber}"
                                                            FontSize="20"
                                                            FontWeight="Bold"
                                                            Background="{Binding Color}"
                                                            Foreground="White"
                                                            ToolTip="{Binding ToolTip}"
                                                            Tag="{Binding SeatNumber}"
                                                            Click="SeatButton_Click">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="8">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Button Content="Înapoi la meniu"
                        Width="200"
                        Height="45"
                        HorizontalAlignment="Left"
                        Click="BackButton_Click"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Eliberează locul tău"
                            Width="220"
                            Height="45"
                            Margin="0,0,15,0"
                            Background="#A8192E"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Click="ReleaseSeatButton_Click"/>

                    <Button Content="Refresh"
                            Width="120"
                            Height="45"
                            Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
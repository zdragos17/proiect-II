<Window x:Class="Proiect.StudyRoomsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Săli de lectură - Rezervare Loc" Height="600" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F7FA" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Rezervare Loc de Studiu" FontSize="26" FontWeight="Bold" Foreground="#2D2D2D" Margin="0,0,0,10"/>
        <TextBlock Text="Alege un loc liber (verde) pentru a-l rezerva. Locurile roșii sunt deja ocupate." 
                   Grid.Row="0" Margin="0,35,0,20" Foreground="#6C757D" FontSize="14"/>

        <ItemsControl x:Name="SeatsItemsControl" Grid.Row="1" Margin="0,10,0,10">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Width="80" Height="80" Margin="10" 
                            Content="{Binding SeatNumber}" FontSize="24" FontWeight="Bold"
                            Background="{Binding Color}" Foreground="White"
                            ToolTip="{Binding ToolTip}"
                            Tag="{Binding SeatNumber}" Click="SeatButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="2" VerticalAlignment="Bottom" Margin="0,0,0,20">
            <Button Content="Înapoi la meniu"
                    Width="180"
                    Height="45"
                    HorizontalAlignment="Left"
                    Click="BackButton_Click"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Eliberează locul"
                        Width="180"
                        Height="45"
                        Margin="0,0,10,0"
                        Background="#A8192E"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Click="ReleaseSeatButton_Click"/>

                <Button Content="Refresh"
                        Width="120"
                        Height="45"
                        Click="RefreshButton_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
<Window x:Class="Proiect.AssistantChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asistent Bibliotecă" 
        Height="600" 
        Width="500"
        Background="#F5F7FA"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        MinHeight="400"
        MinWidth="350">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#A8192E" Padding="15">
            <TextBlock Text="🤖 Asistent Bibliotecă" 
                       Foreground="White" 
                       FontSize="16" 
                       FontWeight="Bold"/>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="0">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Padding="15">
                <ItemsControl x:Name="ChatMessages" Padding="0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5,0,5">
                                <Border Background="#2D3748" 
                                        CornerRadius="15,15,0,15"
                                        Padding="12,10"
                                        MaxWidth="350"
                                        HorizontalAlignment="Right"
                                        Visibility="{Binding IsUser, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Message}" 
                                               Foreground="White" 
                                               TextWrapping="Wrap" 
                                               FontSize="14"/>
                                </Border>

                                <Border Background="#F1F5F9" 
                                        CornerRadius="15,15,15,0"
                                        Padding="12,10"
                                        MaxWidth="350"
                                        HorizontalAlignment="Left"
                                        Visibility="{Binding IsAssistant, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding Message}" 
                                               Foreground="#1E293B" 
                                               TextWrapping="Wrap" 
                                               FontSize="14"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputTextBox" 
                         Grid.Column="0"
                         Padding="10"
                         FontSize="14"
                         VerticalAlignment="Center"
                         Foreground="#333"
                         Background="#F8FAFC"
                         BorderBrush="#CBD5E1"
                         BorderThickness="1"
                         KeyDown="InputTextBox_KeyDown"
                         TextWrapping="Wrap"
                         MaxHeight="80"
                         VerticalScrollBarVisibility="Auto"/>

                <Button Grid.Column="1" 
                        Content="Trimite" 
                        Click="SendButton_Click"
                        Margin="10,0,0,0"
                        Width="80"
                        Background="#A8192E"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        VerticalAlignment="Stretch">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder" CornerRadius="5" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#C42A42"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
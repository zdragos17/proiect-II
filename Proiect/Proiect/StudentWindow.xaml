<Window x:Class="Proiect.StudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Biblioteca UTCN - Sistem Studenți"
        Height="650"
        Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#C51F35">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="UTCN"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold"/>

                    <TextBlock Text="Biblioteca"
                               Foreground="White"
                               FontSize="14"
                               Margin="0,0,0,35"/>

                    <Button Content="📚 Catalog Cărți"
                            Height="45"
                            Margin="0,0,0,15"
                            FontWeight="SemiBold"
                            Click="ShowAllButton_Click"/>

                    <Button Content="📖 Cărțile Mele"
                            Height="45"
                            Margin="0,0,0,15"
                            FontWeight="SemiBold"
                            Click="MyBooksButton_Click"/>

                    <Button Content="🏛 Săli de lectură"
                            Height="45"
                            FontWeight="SemiBold"
                            Click="StudyRoomsButton_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Content="⎋ Ieșire cont"
                            Height="35"
                            Margin="0,0,0,10"
                            Click="LogoutButton_Click"/>

                    <Button Content="✕ Închide aplicația"
                            Height="35"
                            Click="ExitButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock x:Name="WelcomeTextBlock"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#2D2D2D"/>

                    <TextBlock Text="Explorează catalogul și rezervă cărțile dorite."
                   FontSize="14"
                   Foreground="#6C757D"
                   Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ACTIONS + SEARCH -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="Lista Cărților"
                   FontSize="18"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
                        <Button Content="Caută"
                    Width="90"
                    Height="35"
                    Margin="0,0,10,0"
                    Click="SearchButton_Click"/>

                        <Button Content="Resetează"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="ShowAllButton_Click"/>

                        <Button Content="Refresh"
                    Width="90"
                    Height="35"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="RefreshButton_Click"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <TextBlock Text="Căutare catalog:"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"
                   Foreground="#495057"/>

                    <TextBox x:Name="SearchTextBox"
                 Height="38"
                 Margin="130,0,0,0"
                 TextChanged="SearchTextBox_TextChanged"/>
                </Grid>
            </StackPanel>

            <!-- TABLE -->
            <DataGrid x:Name="BooksDataGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      MouseDoubleClick="BooksDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Titlu" Binding="{Binding Title}" Width="2.5*"/>
                    <DataGridTextColumn Header="Autor" Binding="{Binding Author}" Width="2*"/>
                    <DataGridTextColumn Header="Domeniu" Binding="{Binding Subject}" Width="1.5*"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*"/>
                    <DataGridTextColumn Header="Data rezervării" Binding="{Binding ReservationDate}" Width="1.5*"/>
                    <DataGridTextColumn Header="Data împrumutului" Binding="{Binding BorrowDate}" Width="1.5*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- BOTTOM -->
            <Grid Grid.Row="3" Margin="0,20,0,0">
                <Button Width="60"
                        Height="60"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="#A8192E"
                        Foreground="White"
                        BorderThickness="0"
                        Click="AIAsistentButton_Click"
                        ToolTip="Vorbește cu Asistentul Bibliotecii">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="30">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="🤖" FontSize="26" HorizontalAlignment="Center" Margin="0,0,0,-5"/>
                                    <TextBlock Text="AI" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Rezervă cartea selectată"
                        Width="250"
                        Height="45"
                        HorizontalAlignment="Right"
                        Click="ReserveButton_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
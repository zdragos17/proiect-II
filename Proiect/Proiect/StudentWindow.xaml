<Window x:Class="Proiect.StudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Biblioteca UTCN - Sistem Studenți"
        Height="650"
        Width="1050"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#A8192E" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="25,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="UNIVERSITATEA TEHNICĂ " Foreground="White" FontSize="16" FontWeight="Black"/>
                    <TextBlock Text="DIN CLUJ-NAPOCA" Foreground="White" FontSize="16" FontWeight="Black"/>
                    <TextBlock Text="  |  Biblioteca" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <Button Content="Ieșire cont (Logout)" 
                            Width="160" Margin="0,0,15,0"
                            Style="{StaticResource HeaderButtonStyle}"
                            Click="LogoutButton_Click"/>

                    <Button Content="Închide app" 
                            Width="80" Height="30" 
                            Click="ExitButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#f8d7da"/>
                                <Setter Property="Foreground" Value="#721c24"/>
                                <Setter Property="BorderBrush" Value="#f5c6cb"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#f5c6cb"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#f1b0b7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="25,25,25,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="WelcomeTextBlock" FontSize="24" FontWeight="SemiBold" Foreground="#2D2D2D" Margin="0,0,0,20"/>

            <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                <Button Content="Cărțile Mele" Width="140" Margin="0,0,25,10" Click="MyBooksButton_Click"/>
                <Button Content="Săli de lectură" Width="140" Margin="0,0,25,10" Click="StudyRoomsButton_Click"/>

                <TextBlock Text="Căutare catalog:" VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold" Foreground="#495057"/>
                <TextBox x:Name="SearchTextBox" Width="300" Margin="0,0,15,10" TextChanged="SearchTextBox_TextChanged"/>

                <Button Content="Caută" Width="110" Margin="0,0,10,10" Click="SearchButton_Click"/>

                <Button Content="Resetează" Width="110" Margin="0,0,10,10" 
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Click="ShowAllButton_Click"/>
                <Button Content="Refresh" Width="110" Margin="0,0,0,10" 
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Click="RefreshButton_Click"/>
            </WrapPanel>
        </Grid>

        <DataGrid x:Name="BooksDataGrid"
                  Grid.Row="2"
                  Margin="25,10,25,10"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="BooksDataGrid_MouseDoubleClick" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Titlu" Binding="{Binding Title}" Width="2.5*"/>
                <DataGridTextColumn Header="Autor" Binding="{Binding Author}" Width="2*"/>
                <DataGridTextColumn Header="Domeniu" Binding="{Binding Subject}" Width="1.5*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*"/>
                <DataGridTextColumn Header="Data rezervării" Binding="{Binding ReservationDate}" Width="1.5*"/>
                <DataGridTextColumn Header="Data împrumutului" Binding="{Binding BorrowDate}" Width="1.5*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="25,10,25,25">
            <Button Content="Rezervă cartea selectată" 
                    Width="260" 
                    HorizontalAlignment="Right"
                    Click="ReserveButton_Click"/>
        </Grid>
        <Button Grid.RowSpan="10" 
                Width="60" Height="60" 
                HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                Margin="30,0,0,40"
                Background="#A8192E" Foreground="White"
                BorderThickness="0"
                Click="AIAsistentButton_Click"
                ToolTip="Vorbește cu Asistentul Bibliotecii">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="30">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="🤖" FontSize="26" HorizontalAlignment="Center" Margin="0,0,0,-5"/>
                            <TextBlock Text="AI" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <Button.Style>
                <Style TargetType="Button">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#821323"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
<Window x:Class="Proiect.StudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proiect"
        mc:Ignorable="d"
        Title="Pagina Student"
        Height="600"
        Width="950"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F7FA" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="WelcomeTextBlock"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="My Books"
                    Width="120"
                    Height="35"
                    Margin="0,0,15,0"
                    Click="MyBooksButton_Click"/>
            <Button Content="Logout"
                     Width="100"
                    Height="35"
                    Margin="0,0,15,0"
                     Click="LogoutButton_Click"/>

            <TextBox x:Name="SearchTextBox"
                     Width="300"
                     Height="35"
                     Margin="0,0,15,0"
                     TextChanged="SearchTextBox_TextChanged"/>

            <Button Content="Caută"
                    Width="100"
                    Height="35"
                    Margin="0,0,15,0"
                    Click="SearchButton_Click"/>

            <Button Content="Arată toate"
                    Width="120"
                    Height="35"
                    Click="ShowAllButton_Click"/>
            <Button Content="Refresh"
                      Width="100"
                     Height="35"
                     Margin="0,0,15,0"
                      Click="RefreshButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="BooksDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Titlu" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Autor" Binding="{Binding Author}" Width="*"/>
                <DataGridTextColumn Header="Domeniu" Binding="{Binding Subject}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                <DataGridTextColumn Header="Data rezervării" Binding="{Binding ReservationDate}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2"
                Content="Rezervă cartea selectată"
                Width="180"
                Height="40"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,10,10"
                Click="ReserveButton_Click"/>
    </Grid>
</Window>
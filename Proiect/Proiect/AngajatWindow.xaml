<Window x:Class="Proiect.AngajatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Biblioteca UTCN - Administrare Angajat"
        Height="600"
        Width="850"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#A8192E" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="25,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="UNIVERSITATEA TEHNICĂ " Foreground="White" FontSize="16" FontWeight="Black"/>
                    <TextBlock Text="DIN CLUJ-NAPOCA" Foreground="White" FontSize="16" FontWeight="Black"/>
                    <TextBlock Text="  |  Panou Angajat" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Ieșire cont (Logout)" 
                            Width="160" Margin="0,0,15,0"
                            Style="{StaticResource HeaderButtonStyle}"
                            Click="LogoutButton_Click"/>

                    <Button Content="Închide app" 
                            Width="80" Height="30" 
                            Click="ExitButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#f8d7da"/>
                                <Setter Property="Foreground" Value="#721c24"/>
                                <Setter Property="BorderBrush" Value="#f5c6cb"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#f5c6cb"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#f1b0b7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="25,25,25,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="WelcomeTextBlock" FontSize="24" FontWeight="SemiBold" Foreground="#2D2D2D" Margin="0,0,0,20"/>

            <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="Caută student " VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold" Foreground="#495057"/>
                <TextBox x:Name="SearchStudentTextBox"
                         Width="300" Margin="0,0,10,10"
                         TextChanged="SearchStudentTextBox_TextChanged"/>

                <Button Content="Caută" Width="110" Margin="0,0,10,10" Click="SearchStudentButton_Click"/>

                <Button Content="Arată toți" Width="110" Margin="0,0,10,10" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="ShowAllStudentsButton_Click"/>
            </WrapPanel>
        </Grid>

        <DataGrid x:Name="StudentsDataGrid"
                  Grid.Row="2"
                  Margin="25,10,25,10"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="StudentsDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Username"
                        Binding="{Binding Username}"
                        Width="*"/>

                <DataGridTextColumn Header="Nume"
                        Binding="{Binding LastName}"
                        Width="*"/>

                <DataGridTextColumn Header="Prenume"
                        Binding="{Binding FirstName}"
                        Width="*"/>

                <DataGridTextColumn Header="Facultate"
                        Binding="{Binding Faculty}"
                        Width="*"/>

                <DataGridTextColumn Header="Număr matricol"
                        Binding="{Binding MatriculationNumber}"
                        Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="25,10,25,25">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Descarcă cărți (API)" 
                        Width="160" 
                        Click="DownloadApiBooks_Click"/>

                <Button Content="Adaugă Carte Manual" 
                        Width="160" 
                        Margin="15,0,0,0"
                        Click="AddBookManual_Click"/>
            </StackPanel>

            <Button Content="Deschide fișa studentului" 
                    Width="260" 
                    HorizontalAlignment="Right"
                    Click="OpenStudentFileButton_Click"/>
        </Grid>
    </Grid>
</Window>
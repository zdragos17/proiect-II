<Window x:Class="Proiect.MyBooksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proiect"
        mc:Ignorable="d"
        Title="My Books"
        Height="500"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F7FA" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <DataGrid x:Name="MyBooksDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Titlu" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Autor" Binding="{Binding Author}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                <DataGridTextColumn Header="Data rezervării" Binding="{Binding ReservationDate}" Width="*"/>
                <DataGridTextColumn Header="Data împrumutului" Binding="{Binding BorrowDate}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="Back"
                    Width="100"
                    Height="35"
                    Click="BackButton_Click"/>

            <Button Grid.Column="2"
                    Content="Refresh"
                    Width="100"
                    Height="35"
                    Click="RefreshButton_Click"/>
        </Grid>
    </Grid>
</Window>